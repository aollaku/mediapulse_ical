
import io
import os
import uuid
from datetime import date, datetime, timedelta
from pathlib import Path

import fitz  # PyMuPDF
import numpy as np
from PIL import Image
from flask import (
    Flask, flash, redirect, render_template, request, send_file, session, url_for
)
from icalendar import Calendar, Event
from werkzeug.utils import secure_filename

try:
    import caldav
except Exception:
    caldav = None

APP_DIR = Path(__file__).resolve().parent
UPLOAD_DIR = APP_DIR / "uploads"
UPLOAD_DIR.mkdir(exist_ok=True)

app = Flask(__name__)
app.secret_key = os.environ.get("FLASK_SECRET_KEY", "change-me-please")

CALENDAR_NAMES = {
    "work": "MediaPulse Work",
    "ot": "MediaPulse Overtime",
    "unavailable": "MediaPulse Unavailable/Leave",
    "off": "MediaPulse Off",
}

PALETTE = {
    "work": (197, 229, 184),         # light green
    "ot": (230, 150, 150),           # red-ish
    "unavailable": (190, 220, 245),  # light blue
    "off": (240, 240, 240),          # white/grey fallback
}


def hex_to_rgb(hex_str: str):
    value = hex_str.strip().lstrip("#")
    if len(value) != 6:
        raise ValueError("Hex color must be 6 characters.")
    return tuple(int(value[i:i+2], 16) for i in (0, 2, 4))


def dominant_rgb(img: Image.Image):
    arr = np.asarray(img.convert("RGB"))
    arr = arr.reshape((-1, 3)).astype(np.float32)
    # Drop near-black text pixels to bias toward background cell fill.
    brightness = arr.mean(axis=1)
    arr = arr[brightness > 80]
    if len(arr) == 0:
        return (255, 255, 255)
    return tuple(int(x) for x in arr.mean(axis=0))


def color_distance(a, b):
    return sum((int(a[i]) - int(b[i])) ** 2 for i in range(3)) ** 0.5


def classify_cell(rgb, custom_palette):
    distances = {k: color_distance(rgb, v) for k, v in custom_palette.items()}
    best = min(distances, key=distances.get)
    # Treat clearly white-ish cells as off, even if custom colors drift a bit.
    if sum(rgb) / 3 > 236:
        return "off"
    return best


def render_pdf_first_page(pdf_path: Path) -> Path:
    doc = fitz.open(pdf_path)
    page = doc.load_page(0)
    pix = page.get_pixmap(matrix=fitz.Matrix(2, 2), alpha=False)
    img_path = UPLOAD_DIR / f"{pdf_path.stem}_page1.png"
    pix.save(img_path)
    return img_path


def crop_with_bounds(img: Image.Image, box):
    left, top, right, bottom = box
    left = max(0, int(left))
    top = max(0, int(top))
    right = min(img.width, int(right))
    bottom = min(img.height, int(bottom))
    return img.crop((left, top, right, bottom))


def build_events_from_selection(image_path: Path, month_start: date, row_box, first_day_x, last_day_x, day_count, palette):
    img = Image.open(image_path)
    row_img = crop_with_bounds(img, row_box)

    x0 = float(first_day_x)
    x1 = float(last_day_x)
    if x1 <= x0:
        raise ValueError("Last day marker must be to the right of first day marker.")

    cell_width = (x1 - x0) / max(day_count - 1, 1)
    day_entries = []

    # Convert page coordinates to row-relative coordinates
    row_left = row_box[0]
    rel_first = x0 - row_left
    rel_last = x1 - row_left

    for idx in range(day_count):
        cell_center_x = rel_first + idx * cell_width
        left = cell_center_x - (cell_width * 0.38)
        right = cell_center_x + (cell_width * 0.38)
        top = row_img.height * 0.18
        bottom = row_img.height * 0.82
        cell_img = crop_with_bounds(row_img, (left, top, right, bottom))
        rgb = dominant_rgb(cell_img)
        label = classify_cell(rgb, palette)
        event_date = month_start + timedelta(days=idx)
        day_entries.append({
            "date": event_date.isoformat(),
            "label": label,
            "rgb": list(rgb),
            "title": default_title(label),
        })
    return day_entries


def default_title(label):
    return {
        "work": "Work",
        "ot": "Overtime",
        "unavailable": "Unavailable / Leave",
        "off": "Off",
    }.get(label, "Roster")


def make_ical(events, label=None):
    cal = Calendar()
    cal.add("prodid", "-//MediaPulse iCal Sync//OpenAI//EN")
    cal.add("version", "2.0")
    cal.add("calscale", "GREGORIAN")

    for entry in events:
        if label and entry["label"] != label:
            continue
        ev = Event()
        start = date.fromisoformat(entry["date"])
        ev.add("uid", f"{uuid.uuid4()}@mediapulse-local")
        ev.add("dtstamp", datetime.utcnow())
        ev.add("dtstart", start)
        ev.add("dtend", start + timedelta(days=1))
        ev.add("summary", entry.get("title") or default_title(entry["label"]))
        ev.add("description", f"Imported from MediaPulse PDF. Type: {entry['label']}")
        ev.add("categories", entry["label"])
        ev.add("X-MEDIAPULSE-AUTO", "1")
        cal.add_component(ev)
    return cal.to_ical()


def ensure_calendar(principal, name):
    calendars = principal.calendars()
    for cal in calendars:
        try:
            if cal.name == name:
                return cal
        except Exception:
            pass
    return principal.make_calendar(name=name)


def daterange_month_bounds(events):
    if not events:
        today = date.today()
        start = today.replace(day=1)
    else:
        start = date.fromisoformat(min(e["date"] for e in events)).replace(day=1)
    if start.month == 12:
        end = start.replace(year=start.year + 1, month=1, day=1)
    else:
        end = start.replace(month=start.month + 1, day=1)
    return start, end


def sync_to_icloud(events, url, username, password, replace_existing=False):
    if caldav is None:
        raise RuntimeError("caldav library is not installed.")
    client = caldav.DAVClient(url=url, username=username, password=password)
    principal = client.principal()

    start, end = daterange_month_bounds(events)

    grouped = {k: [] for k in CALENDAR_NAMES}
    for entry in events:
        grouped[entry["label"]].append(entry)

    results = []
    for label, items in grouped.items():
        if not items:
            continue
        cal = ensure_calendar(principal, CALENDAR_NAMES[label])

        if replace_existing:
            try:
                for found in cal.date_search(start, end):
                    raw = found.data
                    if "X-MEDIAPULSE-AUTO:1" in raw or "Imported from MediaPulse PDF" in raw:
                        found.delete()
            except Exception:
                # Safe fallback: do not block full sync if cleanup fails.
                pass

        for entry in items:
            cal.add_event(make_ical([entry]).decode("utf-8"))
        results.append((label, len(items), CALENDAR_NAMES[label]))
    return results


@app.route("/", methods=["GET", "POST"])
def index():
    if request.method == "POST":
        pdf_file = request.files.get("pdf_file")
        if not pdf_file or not pdf_file.filename.lower().endswith(".pdf"):
            flash("Please upload a PDF file.")
            return redirect(url_for("index"))

        month_start_raw = request.form.get("month_start", "").strip()
        day_count_raw = request.form.get("day_count", "").strip()

        try:
            month_start = date.fromisoformat(month_start_raw)
            day_count = int(day_count_raw)
            if day_count < 1 or day_count > 31:
                raise ValueError
        except Exception:
            flash("Enter a valid month start date and day count.")
            return redirect(url_for("index"))

        filename = secure_filename(pdf_file.filename)
        pdf_path = UPLOAD_DIR / filename
        pdf_file.save(pdf_path)

        image_path = render_pdf_first_page(pdf_path)

        session["image_path"] = str(image_path)
        session["month_start"] = month_start.isoformat()
        session["day_count"] = day_count
        session["employee_name"] = request.form.get("employee_name", "").strip()

        # Optional custom palette
        palette = {}
        for label in ("work", "ot", "unavailable", "off"):
            raw = request.form.get(f"color_{label}", "").strip()
            palette[label] = hex_to_rgb(raw) if raw else PALETTE[label]
        session["palette"] = {k: list(v) for k, v in palette.items()}

        return redirect(url_for("select"))

    return render_template("index.html", palette=PALETTE)


@app.route("/select", methods=["GET", "POST"])
def select():
    image_path = session.get("image_path")
    if not image_path:
        flash("Start by uploading a PDF.")
        return redirect(url_for("index"))

    if request.method == "POST":
        try:
            row_left = float(request.form["row_left"])
            row_top = float(request.form["row_top"])
            row_right = float(request.form["row_right"])
            row_bottom = float(request.form["row_bottom"])
            first_day_x = float(request.form["first_day_x"])
            last_day_x = float(request.form["last_day_x"])
        except Exception:
            flash("Please complete the row and date selection.")
            return redirect(url_for("select"))

        palette = {k: tuple(v) for k, v in session["palette"].items()}
        events = build_events_from_selection(
            Path(image_path),
            date.fromisoformat(session["month_start"]),
            (row_left, row_top, row_right, row_bottom),
            first_day_x,
            last_day_x,
            int(session["day_count"]),
            palette,
        )
        session["events"] = events
        session["row_box"] = [row_left, row_top, row_right, row_bottom]
        session["first_day_x"] = first_day_x
        session["last_day_x"] = last_day_x
        return redirect(url_for("review"))

    return render_template(
        "select.html",
        image_url=url_for("uploaded_image"),
        employee_name=session.get("employee_name", ""),
        month_start=session.get("month_start"),
        day_count=session.get("day_count"),
    )


@app.route("/uploaded-image")
def uploaded_image():
    image_path = session.get("image_path")
    if not image_path:
        return "", 404
    return send_file(image_path, mimetype="image/png")


@app.route("/review", methods=["GET", "POST"])
def review():
    events = session.get("events")
    if not events:
        flash("Please select the row first.")
        return redirect(url_for("select"))

    if request.method == "POST":
        updated = []
        for idx, old in enumerate(events):
            label = request.form.get(f"label_{idx}", old["label"])
            title = request.form.get(f"title_{idx}", default_title(label)).strip() or default_title(label)
            updated.append({
                "date": old["date"],
                "label": label,
                "rgb": old["rgb"],
                "title": title,
            })
        session["events"] = updated

        action = request.form.get("action")
        if action == "download":
            return redirect(url_for("download_zip"))
        if action == "sync":
            return redirect(url_for("sync"))
        flash("Saved review changes.")
        return redirect(url_for("review"))

    return render_template("review.html", events=events)


@app.route("/download-zip")
def download_zip():
    events = session.get("events")
    if not events:
        flash("Nothing to export yet.")
        return redirect(url_for("index"))

    memory = io.BytesIO()
    import zipfile
    with zipfile.ZipFile(memory, "w", zipfile.ZIP_DEFLATED) as zf:
        all_ics = make_ical(events)
        zf.writestr("mediapulse_all.ics", all_ics)
        for label, filename in {
            "work": "mediapulse_work.ics",
            "ot": "mediapulse_overtime.ics",
            "unavailable": "mediapulse_unavailable_leave.ics",
            "off": "mediapulse_off.ics",
        }.items():
            zf.writestr(filename, make_ical(events, label=label))
    memory.seek(0)
    return send_file(memory, as_attachment=True, download_name="mediapulse_ical_exports.zip", mimetype="application/zip")


@app.route("/sync", methods=["GET", "POST"])
def sync():
    events = session.get("events")
    if not events:
        flash("Nothing to sync yet.")
        return redirect(url_for("index"))

    if request.method == "POST":
        url = request.form.get("caldav_url", "").strip()
        username = request.form.get("username", "").strip()
        password = request.form.get("password", "").strip()
        replace_existing = request.form.get("replace_existing") == "on"

        try:
            results = sync_to_icloud(events, url, username, password, replace_existing=replace_existing)
            flash("Sync completed: " + ", ".join(f"{count} to {name}" for _, count, name in results))
            return redirect(url_for("review"))
        except Exception as exc:
            flash(f"Sync failed: {exc}")

    return render_template("sync.html")


if __name__ == "__main__":
    app.run(debug=True, port=5001)
